{
  "expo": {
    "name": "eleva_app",
    "slug": "eleva_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#18191A"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
		"bundleIdentifier": "com.dwitmexico.elevaapp",
		"supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.marte1309.eleva_app"
	},
	"androidNavigationBar": {
		"visible": true,
		"barStyle": "",
		"backgroundColor": "#18191A"
	}
  }
}
